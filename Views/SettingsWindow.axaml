<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SubLingo.Views.SettingsWindow"
        Title="SubLingo — Ayarlar"
        Width="480" Height="440"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#16161A">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#A0A0B0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0D0D0F"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#2A2A30"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#0D0D0F"/>
            <Setter Property="Foreground" Value="#E8E8EA"/>
            <Setter Property="BorderBrush" Value="#2A2A30"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Styles>

    <ScrollViewer>
        <StackPanel Margin="28" Spacing="16">

            <TextBlock Text="⚙  Ayarlar"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"/>

            <!-- SRT Dosyası -->
            <StackPanel Spacing="5">
                <TextBlock Text="SRT Dosya Yolu" Classes="label"/>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="TbSrtPath"
                             Grid.Column="0"
                             Watermark="örn: /home/user/got_s01e01.srt"/>
                    <Button Grid.Column="1"
                            Content="..."
                            Margin="6,0,0,0"
                            Padding="14,8"
                            Background="#2A2A30"
                            Foreground="White"
                            CornerRadius="8"
                            Cursor="Hand"
                            Click="BtnBrowse_Click"/>
                </Grid>
            </StackPanel>

            <!-- VLC Port -->
            <StackPanel Spacing="5">
                <TextBlock Text="VLC HTTP Port (varsayılan: 8080)" Classes="label"/>
                <TextBox x:Name="TbVlcPort"/>
            </StackPanel>

            <!-- VLC Şifre -->
            <StackPanel Spacing="5">
                <TextBlock Text="VLC HTTP Şifresi (opsiyonel)" Classes="label"/>
                <TextBox x:Name="TbVlcPassword"
                         PasswordChar="●"
                         Watermark="boş bırakabilirsin"/>
            </StackPanel>

            <!-- Dil -->
            <StackPanel Spacing="5">
                <TextBlock Text="Çeviri Dili" Classes="label"/>
                <ComboBox x:Name="CbLang" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Türkçe" Tag="tr"/>
                    <ComboBoxItem Content="Almanca" Tag="de"/>
                    <ComboBoxItem Content="Fransızca" Tag="fr"/>
                    <ComboBoxItem Content="İspanyolca" Tag="es"/>
                    <ComboBoxItem Content="İtalyanca" Tag="it"/>
                </ComboBox>
            </StackPanel>

            <!-- DeepL -->
            <StackPanel Spacing="5">
                <TextBlock Text="DeepL API Key (opsiyonel — daha iyi çeviri)" Classes="label"/>
                <TextBox x:Name="TbDeepL"
                         Watermark="Yoksa Google Translate kullanılır"/>
                <TextBlock Text="deepl.com/pro-api → Free plan → API key al"
                           FontSize="11"
                           Foreground="#555555"/>
            </StackPanel>

            <!-- Kaydet -->
            <Button Content="💾  Kaydet ve Başlat"
                    HorizontalAlignment="Right"
                    Padding="20,10"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#6366F1"
                    Foreground="White"
                    CornerRadius="10"
                    Cursor="Hand"
                    Click="BtnSave_Click"/>

        </StackPanel>
    </ScrollViewer>
</Window>
